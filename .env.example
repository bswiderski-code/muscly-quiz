# =============================================================================
# Database
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/musclepals_quiz?schema=public"

# =============================================================================
# Site URLs (browser / SEO)
# =============================================================================
# Origin where this app is reachable in the current environment (no trailing slash).
NEXT_PUBLIC_BASE_URL="http://localhost:3003"
# Hostname only for this quiz app — middleware redirects production traffic here.
NEXT_PUBLIC_CANONICAL_HOST="quiz.musclepals.com"
# Marketing site — logo, legal links, etc.
NEXT_PUBLIC_MAIN_SITE_URL="https://musclepals.com"

# =============================================================================
# Payments — secrets only via env (never commit real values)
# =============================================================================
# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayU (OAuth client id/secret, POS id, second key / MD5)
PAYU_SANDBOX="true"
PAYU_CLIENT_ID=""
PAYU_CLIENT_SECRET=""
PAYU_POS_ID=""
PAYU_SECOND_KEY=""

# Przelewy24
P24_SANDBOX="true"
P24_MERCHANT_ID=""
P24_POS_ID=""
P24_API_KEY=""
P24_CRC=""

# PDF files on S3-compatible storage (Hetzner, R2, etc.)
# Use either S3_PDF_* or standard AWS_* for keys/region.
S3_PDF_BUCKET=""
# S3_PDF_REGION="eu-central-1"
# S3_PDF_ENDPOINT="https://your-compat-s3-endpoint"  # optional
# S3_PDF_ACCESS_KEY_ID=""
# S3_PDF_SECRET_ACCESS_KEY=""

# Polish checkout: PL provider override (payu | p24 | stripe); sandbox flag for PL flow
PL_PAYMENT_SANDBOX="true"
PL_PAYMENT_PROVIDER="payu"

# =============================================================================
# Automation / webhooks
# =============================================================================
N8N_WEBHOOK_URL="https://n8n.example.com/webhook/endpoint"
# Optional: HMAC or shared secret for signing outbound N8N payloads (see lib/n8n.ts)
N8N_WEBHOOK_SECRET=""

# =============================================================================
# Operations
# =============================================================================
# When "true", all non-API pages redirect to /{locale}/technical-issues
TECHNICAL_ISSUES_MODE="false"

# =============================================================================
# Admin / internal APIs
# =============================================================================
# Required on POST /api/exchange-rates — must match X-Admin-Secret header
# Local one-shot refresh (dev server running, default port 3003): pnpm exchange-rates:refresh
EXCHANGE_RATE_APIKEY=""
# Optional: override URL for scripts/refresh-exchange-rates.sh (default http://127.0.0.1:$PORT/api/exchange-rates)
# EXCHANGE_RATES_REFRESH_URL="http://127.0.0.1:3000/api/exchange-rates"
