# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/musclepals_quiz?schema=public"

# Payment Environment Config
# These flags determine whether to use the sandbox or production credentials defined in config/credentials.ts
PAYU_SANDBOX="true"
P24_SANDBOX="true"
STRIPE_SANDBOX="true"

# Polish Market Specifics
PL_PAYMENT_SANDBOX="true"
PL_PAYMENT_PROVIDER="payu" # Options: "payu" or "p24"

# Integrations
N8N_WEBHOOK_URL="https://n8n.example.com/webhook/endpoint"

# Site Configuration & Development overrides
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
# Quiz app canonical hostname (no protocol) — used with middleware / metadata
NEXT_PUBLIC_CANONICAL_HOST="quiz.musclepals.com"
# Main marketing site (with protocol) — logo/back links, legal URLs routed off-site
NEXT_PUBLIC_MAIN_SITE_URL="https://musclepals.com"

# Spoofing (Development only)
# Used to simulate different domains/locales locally
# SPOOFING="true"
# DEV_URL="http://localhost:3000"
# SPOOFED="quiz.musclepals.com"
