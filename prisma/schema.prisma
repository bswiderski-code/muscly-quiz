// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================
enum OrderItem {
  workout_solo
  workout_bundle
  raport
  calisthenics_solo
  calisthenics_bundle

  @@map("order_item")
}

enum UserStatus {
  paid
  pending
  failed

  @@map("user_status")
}

enum Gender {
  M
  F

  @@map("gender")
}

enum ActivityLevel {
  low_activity
  some_activity
  light_training
  regular_training
  hard_work

  @@map("activity_level")
}

enum DietGoal {
  bulk
  cut

  @@map("diet_goal")
}

enum Experience {
  none
  just_started
  some_experience
  advanced

  @@map("experience")
}

enum Difficulty {
  motivation
  effects
  insecurity
  diet
  no_difficulty

  @@map("difficulty")
}

enum Location {
  gym
  house

  @@map("location")
}

enum BalancePriority {
  balance
  prioritized
  onlyupper
  onlylower

  @@map("balance_priority")
}

// ==================== ORDERS ====================
model Orders {
  id               Int       @id @default(autoincrement())
  userId           Int? // relation to user_data
  user             UserData? @relation("UserOrders", fields: [userId], references: [id])
  item             OrderItem
  country          String
  createdAt        DateTime  @default(now())
  amount           Decimal   @db.Decimal(10, 2)
  deliveredAt      Boolean   @default(false)
  currency         String
  payment_provider String

  @@map("orders")
}

// ==================== USER DATA ====================
model UserData {
  id        Int            @id @default(autoincrement()) // userId
  sid       String
  status    UserStatus
  name      String
  email     String
  item      OrderItem
  country   String? // two letters code
  createdAt DateTime       @default(now()) // Europe/Warsaw timezone must be handled in app layer
  orders    Orders[]       @relation("UserOrders")
  health    HealthDetails?

  @@map("user_data")
}

// ==================== HEALTH DETAILS ====================
model HealthDetails {
  userId        Int             @id
  user          UserData        @relation(fields: [userId], references: [id])
  gender        Gender
  activity      ActivityLevel
  bmi           Float
  tdee          Float
  bodyfat       String
  diet_goal     DietGoal
  frequency     Int
  experience    Experience
  location      Location
  priority      String
  equipment     String
  sleep         String
  fitness_level Int // 1 to 10
  difficulty    Difficulty
  weight        Float
  height        Float
  duration      Int
  pushups       String
  pullups       String
  cardio        Boolean
  balance       BalancePriority
  age           Int

  @@map("health_details")
}
