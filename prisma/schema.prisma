// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"] // Required to use specific DB schemas
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["Musclepals"] // Defines the schema used
}

model TrainingPlan {
  id            Int      @id @default(autoincrement())
  sid           String   @unique // session id
  amount        Float
  item          String?  // Renamed from "description"
  currency      String
  status        String
  name          String?
  email         String?
  age           Int?
  gender        String?
  activity      String?
  bmi           Float?
  tdee          Int?
  bodyfat       String?
  diet_goal     String?
  frequency     Int?
  experience    String?
  location      String?
  priority      String?
  equipment     String?
  sleep         String?
  fitness_level Int?
  difficulty    String?
  weight        Float?
  height        Float?
  duration      Int?
  pushups       String?
  pullups       String?
  cardio        Boolean?
  balance       String?
  createdAt     DateTime @default(now())
  paymenturl    String?
  // paymentId removed

  @@map("Training_Plans")
  @@schema("Musclepals")
}

model Orders {
  id               Int       @id @default(autoincrement())
  item             String    // opis sprzedanego produktu, np. "raport"
  name             String
  email            String
  checkoutId       Int       // id w tabeli checkoutu (tu: TrainingPlan.id), bez relacji FK
  // checkoutDB removed
  sid              String    // Renamed from "sessionId" to match TrainingPlan
  amount           Int
  currency         String    // teraz "PLN"
  country          String    // teraz "PL"
  payment_provider String    // teraz "Przelewy24"
  createdAt        DateTime  @default(now())
  // paymentId removed
  n8n_exec         String?   // może być null
  deliveredAt      DateTime?

  @@schema("Musclepals")
}