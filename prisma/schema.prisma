// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================
enum OrderItem {
  workout_solo
  workout_bundle
  raport

  @@map("order_item")
}

enum UserStatus {
  paid
  pending
  failed

  @@map("user_status")
}

enum Gender {
  M
  F

  @@map("gender")
}

enum ActivityLevel {
  low_activity
  some_activity
  light_training
  regular_training
  hard_work

  @@map("activity_level")
}

enum DietGoal {
  bulk
  cut

  @@map("diet_goal")
}

enum Experience {
  none
  just_started
  some_experience
  advanced

  @@map("experience")
}

enum Difficulty {
  motivation
  effects
  insecurity
  diet
  no_difficulty

  @@map("difficulty")
}

enum Location {
  gym
  house

  @@map("location")
}


// ==================== ORDERS ====================
model Order {
  id              Int       @id @default(autoincrement())
  country         String
  createdAt       DateTime  @default(now()) @db.Timestamptz
  amount          Decimal   @db.Decimal(10, 2)
  currency        String
  paymentProvider String    @map("payment_provider")
  delivered       Boolean   @default(false)
  userId          Int?      @map("userid")
  item            OrderItem
  pdfToken        String?   @unique @default(uuid())
  amountPln       Decimal   @default(0) @map("amount_pln") @db.Decimal(10, 2)
  user_data       UserData? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt], map: "idx_orders_createdAt")
  @@map("orders")
}

// ==================== ANALYTICS ====================
model AnalyticsHourlyStat {
  id              Int       @id @default(autoincrement())
  bucketStart     DateTime  @map("bucket_start")
  country         String?
  totalOrders     Int       @default(0) @map("total_orders")
  totalRevenuePln Decimal   @default(0) @map("total_revenue_pln") @db.Decimal(10, 2)
  updatedAt       DateTime? @default(now()) @map("updated_at")

  @@index([bucketStart], map: "idx_analytics_bucket")
  @@map("analytics_hourly_stats")
}

// ==================== USER DATA ====================
model UserData {
  id        Int            @id @default(autoincrement()) // userId
  sid       String
  status    UserStatus
  name      String
  email     String
  item      OrderItem
  country   String? // two letters code
  createdAt DateTime       @default(now()) // Europe/Warsaw timezone must be handled in app layer
  orders    Order[]
  health    HealthDetails?

  @@map("user_data")
}

// ==================== HEALTH DETAILS ====================
model HealthDetails {
  userId        Int             @id @map("userid")
  user          UserData        @relation(fields: [userId], references: [id], onDelete: Cascade)
  gender        Gender
  activity      ActivityLevel
  bmi           Float
  tdee          Float
  bodyfat       String
  diet_goal     DietGoal
  frequency     Int
  experience    Experience
  location      Location
  priority      String
  equipment     String
  sleep         String
  fitness_level Int // 1 to 10
  difficulty    Difficulty
  weight        Float
  height        Float
  duration      Int
  pushups       String
  pullups       String
  cardio        Boolean
  age           Int

  @@map("health_details")
}

// ==================== EXCHANGE RATES ====================
model ExchangeRate {
  currency  String   @id
  rate      Decimal  @db.Decimal(10, 4) // Rate to convert FROM currency TO PLN
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("exchange_rates")
}
